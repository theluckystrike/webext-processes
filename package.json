{
  "name": "webext-processes",
  "version": "1.0.0",
  "description": "Typed process management helpers for Chrome extensions — monitor memory, CPU, and manage extension processes. Part of @zovo/webext.",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/theluckystrike/webext-processes.git"
  },
  "homepage": "https://github.com/theluckystrike/webext-processes#readme",
  "bugs": {
    "url": "https://github.com/theluckystrike/webext-processes/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "chrome-extension",
    "chrome-processes",
    "processes",
    "typescript",
    "browser-extension",
    "chrome-api",
    "manifest-v3",
    "webextension",
    "process-manager"
  ],
  "author": "theluckystrike",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  }
}
